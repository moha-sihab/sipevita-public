# .env.example — SIPEVITA Raft Network Docker Compose environment template
#
# Copy this file to .env and adjust if needed before running docker compose.
# The .env file is gitignored. This example file is tracked.
#
# Usage:
#   cd ~/fabric-samples/sipevita-raft-network
#   cp compose/.env.example compose/.env
#   docker compose -f compose/compose-raft.yaml -p sipevita-raft up -d

# Fabric image version (must match crypto-config and configtx Fabric version line)
FABRIC_VERSION=2.5.15

# Logging level override (set to DEBUG for troubleshooting; INFO for normal operation)
# FABRIC_LOGGING_SPEC=INFO

# Chaincode execution timeout (increase if chaincode initialization is slow)
# CORE_CHAINCODE_EXECUTETIMEOUT=300s

# NOTE: Do not set private key paths, MSP passwords, or wallet credentials here.
# These are sourced from the mounted crypto material directories.
