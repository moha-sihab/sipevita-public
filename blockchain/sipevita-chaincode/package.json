{
    "name": "sipevita-chaincode",
    "version": "1.0.0",
    "description": "SIPEVITA - Sistem Pencatatan dan Verifikasi Kepemilikan Tanah Berbasis Blockchain",
    "main": "index.js",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "lint": "eslint *.js */**.js",
        "pretest": "npm run lint",
        "test": "nyc mocha --recursive",
        "start": "fabric-chaincode-node start",
        "wallet:create": "node scripts/createWallet.js",
        "test:runtime-extra": "node scripts/runtime-validation-extra.js"
    },
    "engineStrict": true,
    "author": "SIPEVITA Team",
    "license": "Apache-2.0",
    "dependencies": {
        "fabric-contract-api": "^2.5.8",
        "fabric-shim": "^2.5.8",
        "json-stringify-deterministic": "^1.0.0",
        "sort-keys-recursive": "^2.1.0"
    },
    "devDependencies": {
        "chai": "^4.4.1",
        "eslint": "^8.57.0",
        "fabric-network": "^2.2.20",
        "mocha": "^10.4.0",
        "nyc": "^15.1.0",
        "sinon": "^18.0.0",
        "sinon-chai": "^3.7.0"
    },
    "overrides": {
        "@grpc/grpc-js": "1.14.4"
    },
    "nyc": {
        "exclude": [
            "coverage/**",
            "test/**",
            "index.js",
            ".eslintrc.js"
        ],
        "reporter": [
            "text-summary",
            "html"
        ],
        "all": true,
        "check-coverage": true,
        "statements": 100,
        "branches": 100,
        "functions": 100,
        "lines": 100
    }
}
