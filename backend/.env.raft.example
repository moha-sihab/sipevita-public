
# Runtime — Raft backend runs on port 3002 to avoid conflict with default port 3000
NODE_ENV=development
PORT=3002

# Blockchain mode
BLOCKCHAIN_MODE=fabric

# Hyperledger Fabric — Raft network (sipevita-raft-network)

FABRIC_CONNECTION_PROFILE_PATH=/absolute/path/to/fabric-samples/sipevita-raft-network/connection-profiles/connection-raft.json
FABRIC_WALLET_PATH=/absolute/path/to/fabric-samples/sipevita-raft-network/wallet-raft
FABRIC_IDENTITY=appUser
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=sipevita

# Cloudflare Turnstile (public endpoints only)
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=<your-cloudflare-turnstile-secret-key>
