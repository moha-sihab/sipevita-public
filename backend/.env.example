
NODE_ENV=development
PORT=3000

# Supabase 
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Authentication
JWT_SECRET=<generate-a-strong-random-secret>

# Encryption — must be exactly 64 hexadecimal characters (= 32 bytes, AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-characters>

# Blockchain
BLOCKCHAIN_MODE=fabric
FABRIC_CONNECTION_PROFILE_PATH=/absolute/path/to/connection-profile.json
FABRIC_WALLET_PATH=/absolute/path/to/wallet
FABRIC_IDENTITY=appUser
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=sipevita


# Pinata / IPFS document storage (PRIVATE mode is mandatory)

PINATA_JWT=<your-pinata-jwt>
PINATA_GATEWAY=<your-gateway>.mypinata.cloud
PINATA_NETWORK=private
PINATA_SIGNED_URL_EXPIRES_SECONDS=60

# Document upload limits
DOCUMENT_MAX_FILE_SIZE_MB=10
DOCUMENT_MAX_FILES=5
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png

# Cloudflare Turnstile
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=<your-cloudflare-turnstile-secret-key>
